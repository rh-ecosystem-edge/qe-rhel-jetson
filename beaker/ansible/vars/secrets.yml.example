# Example secrets file - copy to secrets.yml and encrypt with ansible-vault
#
# Create encrypted version:
#   cp vars/secrets.yml.example vars/secrets.yml
#   # Edit vars/secrets.yml with your actual credentials
#   ansible-vault encrypt vars/secrets.yml
#
# Or create directly:
#   ansible-vault create vars/secrets.yml

# GitLab registry credentials
registry_user: "Your Name"
registry_pass: "glpat-xxxxxxxxxxxx"

# Optional: Beaker credentials (if not using Kerberos)
# beaker_user: "your_username"
# beaker_pass: "your_password"

