ARG L4T_JETPACK_IMAGE=nvcr.io/nvidia/l4t-jetpack:r36.4.0
FROM ${L4T_JETPACK_IMAGE}

# cuda-samples version — must match the CUDA toolkit in the L4T container.
# Available tags: v12.0-v12.5 (Makefile), v12.8+ (CMake). No v12.6/v12.7 tags exist.
# v12.5 is the latest compatible with CUDA 12.6 toolkit without compute_100 issues.
ARG CUDA_SAMPLES_VERSION=v12.5
# Target categories to build (space-separated)
ARG CUDA_SAMPLES_TARGETS="1_Utilities 0_Introduction"

RUN apt-get update && apt-get install -y cmake pkg-config git libdrm-dev make g++ libfreeimage-dev

# clone cuda-samples from outsource repository on github (l4t container doesn't have newer versions)
RUN git clone --branch ${CUDA_SAMPLES_VERSION} --depth 1 https://github.com/NVIDIA/cuda-samples.git /cuda-samples

# NVRTC samples do JIT compilation at runtime and need CUDA headers (nv/target, cuda/std/*, etc.).
# sdkFindFilePath func only searches relative paths from the executable (search for ../../../include/), 
# so it can't find /usr/local/cuda/include/. 
# fix : Symlinks all CUDA headers into every sample directory after cloning (Covers any future NVRTC header that might be missing)
RUN for sample_dir in $(find /cuda-samples/Samples -mindepth 2 -maxdepth 2 -type d); do \
      for f in /usr/local/cuda/include/*; do \
        ln -sf "$f" "${sample_dir}/" 2>/dev/null; \
      done; \
    done

# Build targeted CUDA samples.
# <= v12.5 uses Makefile , >= v12.8 uses CMake.
# Skips graphical samples (EGL/X11/GL) and missing runtime dependencies.
# Each sample builds into /build/<sample_name>/<sample_name> for easy discovery.
RUN version_num=$(echo ${CUDA_SAMPLES_VERSION} | sed 's/v//;s/\.//'); \
    for target in ${CUDA_SAMPLES_TARGETS}; do \
      target_dir="/cuda-samples/Samples/${target}"; \
      if [ ! -d "${target_dir}" ]; then \
        echo "ERROR: CUDA_SAMPLES_TARGETS='${target}' not found in /cuda-samples/Samples/"; \
        echo "Available sample suites:"; \
        ls -1 /cuda-samples/Samples/; \
        exit 1; \
      fi; \
      echo -e "\n\n=== === ${target} === ===\n"; \
      for sample_dir in $(find ${target_dir} -mindepth 1 -maxdepth 1 -type d); do \
        sample_name=$(basename ${sample_dir}); \
        echo -e "\n\n=== ${sample_name} ==="; \
        # Skip graphical/display samples (won't work on headless Beaker)
        case "${sample_name}" in \
          simpleCUDA2GL|simpleGL|simpleTexture3D|fluidsGL*|postProcessGL|bindlessTexture|marchingCubes|FDTD3dGPU) \
            echo "SKIP (graphical): ${sample_name}"; continue ;; \
          c++11_cuda) \
            echo "SKIP (missing runtime deps): ${sample_name}"; continue ;; \
        esac; \
        # Build in-place — samples run from source dir so .fatbin, .cu, .pgm files are found
        if [ "${version_num}" -lt 128 ] 2>/dev/null && [ -f "${sample_dir}/Makefile" ]; then \
          # Makefile-based (v12.5 and below) — builds binary in sample_dir
          make -C ${sample_dir} -j$(nproc) 2>&1 || \
          echo "FAIL (non-fatal): ${sample_name}"; \
        elif [ -f "${sample_dir}/CMakeLists.txt" ]; then \
          # CMake-based (v12.8+) — builds into sample_dir/build, binary stays alongside data files
          cmake -S ${sample_dir} -B ${sample_dir}/build 2>&1 && \
          cmake --build ${sample_dir}/build -j$(nproc) 2>&1 || \
          echo "FAIL (non-fatal): ${sample_name}"; \
        else \
          echo "SKIP (no build file): ${sample_name}"; \
        fi; \
      done; \
    done

# cuDNN conv_sample (bundled in L4T container at /usr/src/cudnn_samples_v*/conv_sample)
RUN make -C /usr/src/cudnn_samples_v*/conv_sample clean && make -C /usr/src/cudnn_samples_v*/conv_sample -j$(nproc)
