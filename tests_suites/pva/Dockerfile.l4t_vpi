ARG L4T_JETPACK_IMAGE=nvcr.io/nvidia/l4t-jetpack:r36.4.0
FROM ${L4T_JETPACK_IMAGE}
RUN apt-get update && apt-get install -y cmake make g++ libegl1
# COMPILE ONLY — test execution happens via podman run
RUN for dir in /opt/nvidia/vpi3/samples/*; do \
  cmake -S ${dir} -B ${dir}/build && cmake --build ${dir}/build; \
done
COPY run-vpi-tests.sh /opt/run-vpi-tests.sh
RUN chmod +x /opt/run-vpi-tests.sh
